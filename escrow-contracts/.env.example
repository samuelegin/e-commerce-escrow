# ── Required for Sepolia deployment ──────────────────────────
# Your MetaMask wallet private key (NEVER share or commit this)
# Export from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=your_wallet_private_key_here

# Sepolia RPC URL — get one free from Alchemy or Infura
# Alchemy:  https://dashboard.alchemy.com  → Create App → Sepolia → copy HTTPS URL
# Infura:   https://infura.io              → Create Project → Sepolia endpoint
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_api_key_here

# ── Optional — for Etherscan contract verification ───────────
# Get from https://etherscan.io/myapikey (free account)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
